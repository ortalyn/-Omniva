<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Application Verification Portal</title>

  <style>
    body{
      font-family: Arial;
      margin:0;
      padding:0;
      background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
      color:white;
      text-align:center;
    }

    .box{
      background:white;
      color:black;
      max-width:420px;
      margin:40px auto;
      padding:20px;
      border-radius:12px;
    }

    input{
      width:90%;
      padding:10px;
      margin:8px 0;
    }

    button{
      width:95%;
      padding:12px;
      background:green;
      border:none;
      color:white;
      font-weight:bold;
      cursor:pointer;
      margin-top:10px;
    }

    #status{
      margin-top:15px;
      font-weight:bold;
      color:green;
    }

    .links a{
      display:block;
      margin:10px;
      padding:10px;
      background:#111;
      color:white;
      text-decoration:none;
      border-radius:8px;
    }
  </style>
</head>

<body>

<div class="box">

  <h2>Application Verification Portal</h2>

  <p>Submit your application for processing</p>

  <!-- INPUTS -->
  <input id="name" placeholder="Full Name">
  <input id="email" placeholder="Email Address">
  <input id="country" placeholder="Country">

  <button onclick="submitApplication()">Submit Application</button>

  <p id="status"></p>

  <div id="links" class="links" style="display:none;"></div>

</div>

<!-- FIREBASE SCRIPTS -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>

<script>
  // 🔥 FIREBASE CONFIG
  const firebaseConfig = {
    apiKey: "AIzaSyBvyvCUMbOVB0tsobsvImVDVeD7Ar6MK7Y",
    authDomain: "saas-portal-30302.firebaseapp.com",
    databaseURL: "https://saas-portal-30302-default-rtdb.firebaseio.com/",
    projectId: "saas-portal-30302",
    storageBucket: "saas-portal-30302.appspot.com",
    messagingSenderId: "319885619114",
    appId: "1:319885619114:web:2ddaa487fca89ff26145d3"
  };

  // INIT FIREBASE
  firebase.initializeApp(firebaseConfig);
  const db = firebase.database();

  // 🚀 MAIN FUNCTION
  function submitApplication(){

    let name = document.getElementById("name").value;
    let email = document.getElementById("email").value;
    let country = document.getElementById("country").value;

    if(!name || !email || !country){
      alert("Please fill all fields");
      return;
    }

    let appId = "APP-" + Math.random().toString(36).substring(2,8).toUpperCase();

    // SAVE TO FIREBASE
    db.ref("applications").push({
      name,
      email,
      country,
      status: "Pending",
      appId,
      time: Date.now()
    });

    // SHOW STATUS
    document.getElementById("status").innerText =
      "Application Submitted ✔ ID: " + appId;

    // SHOW CONTACT LINKS
    document.getElementById("links").style.display = "block";

    document.getElementById("links").innerHTML = `
      <a href="https://wa.me/18732804513">WhatsApp Support</a>
      <a href="https://t.me/miacwr">Telegram Support</a>
      <a href="mailto:miacarterxoxo17@gmail.com">Email Support</a>
    `;
  }
</script>

</body>
</html>
